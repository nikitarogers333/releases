<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ site.description }}">
  <link rel="stylesheet" href="{{ '/assets/style.css' | url }}">
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ '/feed.xml' | url }}">
</head>
<body>
  <header class="site-header">
    <a class="brand" href="{{ '/' | url }}">{{ site.title }}</a>
    <nav>
      <a href="{{ '/' | url }}">Today</a>
      <a href="{{ '/archive/' | url }}">Archive</a>
      <a href="{{ '/feed.xml' | url }}">RSS</a>
    </nav>
  </header>
  <main>
    {{ content | safe }}
  </main>
  <footer class="site-footer">
    <p>Built with Eleventy. Run <code>npm run fetch</code> locally, then <code>npm run build</code>.</p>
  </footer>
</body>
</html>
